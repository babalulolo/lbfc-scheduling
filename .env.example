# Session secret - change this to a random string in production
SESSION_SECRET=change-me-to-a-random-string

# Coordinator email - receives notifications when volunteers sign up
COORDINATOR_EMAIL=coordinator@lbfoodcoalition.org

# From email for outgoing notifications
FROM_EMAIL=noreply@lbfoodcoalition.org

# SMTP settings for email notifications (optional for dev, required for production)
# Recommended: use a free service like Resend, Mailgun, or Gmail SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
